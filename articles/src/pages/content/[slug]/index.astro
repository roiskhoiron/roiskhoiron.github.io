---
// articles/src/pages/content/[slug]/index.astro
// Learning Hub landing page — "One Topic, Multiple Ways to Learn"
import HubLayout from '../../../layouts/HubLayout.astro';
import yaml from 'js-yaml';
import { readFile, readdir } from 'node:fs/promises';
import path from 'node:path';

export async function getStaticPaths() {
  const contentDir = path.resolve('..', '..', 'content');
  let entries;
  try {
    entries = await readdir(contentDir, { withFileTypes: true });
  } catch {
    return [];
  }
  const slugs = entries
    .filter(e => e.isDirectory() && !e.name.startsWith('.'))
    .map(e => e.name);

  return slugs.map(slug => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

// Load meta.yaml
let meta = { title: slug, description: '', paths: {}, related: [], tags: [] };
try {
  const metaPath = path.resolve('..', '..', 'content', slug, 'meta.yaml');
  const raw = await readFile(metaPath, 'utf-8');
  meta = yaml.load(raw);
} catch (e) {
  console.warn(`No meta.yaml for ${slug}:`, e.message);
}

const baseUrl = `/articles/content/${slug}`;

const sections = [
  {
    id: 'read',
    icon: '📖',
    title: 'Read',
    desc: 'Pahami konsep dan teori dengan artikel mendalam.',
    enabled: meta.paths?.read?.enabled,
    duration: meta.paths?.read?.duration,
    url: `${baseUrl}/read/`,
    btnLabel: 'Mulai Membaca',
  },
  {
    id: 'practice',
    icon: '🎯',
    title: 'Practice',
    desc: 'Bikin project mini dengan panduan langkah demi langkah.',
    enabled: meta.paths?.practice?.enabled,
    duration: meta.paths?.practice?.duration,
    url: `${baseUrl}/practice/`,
    btnLabel: 'Mulai Praktek',
  },
  {
    id: 'watch',
    icon: '🎬',
    title: 'Watch',
    desc: 'Tonton presentasi visual yang menjelaskan konsep inti.',
    enabled: meta.paths?.watch?.enabled,
    duration: meta.paths?.watch?.duration,
    url: `${baseUrl}/watch/`,
    btnLabel: 'Tonton Presentasi',
  },
  {
    id: 'play',
    icon: '🎮',
    title: 'Play',
    desc: 'Eksperimen interaktif — main sambil belajar.',
    enabled: meta.paths?.play?.enabled,
    duration: meta.paths?.play?.duration || 'Coming Soon',
    url: '#',
    btnLabel: 'Segera Hadir',
  },
];
---

<HubLayout title={meta.title} description={meta.description} slug={slug}>
  <h1>{meta.title || slug}</h1>
  <p class="hub-subtitle">{meta.description || 'Pilih gaya belajar kamu.'}</p>

  <div class="hub-grid">
    {sections.map(s => (
      s.enabled ? (
        <a href={s.url} class="hub-card" style="text-decoration: none; color: inherit;">
          <div class="hub-card-icon">{s.icon}</div>
          <div class="hub-card-title">{s.title}</div>
          <div class="hub-card-desc">{s.desc}</div>
          <div class="hub-card-meta">
            <span class="hub-badge">{s.duration}</span>
          </div>
          <span class="hub-btn">{s.btnLabel}</span>
        </a>
      ) : (
        <div class="hub-card hub-card-disabled">
          <div class="hub-card-icon">{s.icon}</div>
          <div class="hub-card-title">{s.title}</div>
          <div class="hub-card-desc">{s.desc}</div>
          <div class="hub-card-meta">
            <span class="hub-badge hub-badge-disabled" style="background:#e2e8f0;color:#94a3b8;">{s.duration}</span>
          </div>
          <span class="hub-btn hub-btn-secondary">{s.btnLabel}</span>
        </div>
      )
    ))}
  </div>

  {meta.related?.length > 0 && (
    <div class="hub-section">
      <h2>🔗 Topik Terkait</h2>
      <div class="hub-related">
        {meta.related.map(r => (
          <a href={`/articles/content/${r}/`} class="hub-tag">{r.replace(/-/g, ' ')}</a>
        ))}
      </div>
    </div>
  )}

  {meta.tags?.length > 0 && (
    <div class="hub-section" style="margin-top:1.5rem;">
      <h2>🏷️ Tag</h2>
      <div class="hub-related">
        {meta.tags.map(t => (
          <span class="hub-tag" style="cursor:default;">#{t}</span>
        ))}
      </div>
    </div>
  )}
</HubLayout>
