---
import { getCollection, getEntry } from "astro:content";
import { SlideViewer } from "@/components/slide/slide-viewer";

export async function getStaticPaths() {
  const slides = await getCollection("courseSlideResources");
  return slides.map((slide) => {
    const parts = slide.id.split("/");
    return {
      params: { courseId: parts[0], slideId: parts[2] },
    };
  });
}

const { courseId, slideId } = Astro.params;

if (!courseId || !slideId) {
  return Astro.redirect("/404");
}

const slideResource = await getEntry(
  "courseSlideResources",
  `${courseId}/slides/${slideId}`,
);
if (!slideResource) return Astro.redirect("/404");

const coverMD = slideResource.data.title
  ? `## ${slideResource.data.title}\n---\n`
  : "";
const content = `${coverMD}${slideResource.body ?? ""}`;
const { theme, transition, controls, progress } = slideResource.data;
---

<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>
    <div class="container">
      <SlideViewer
        client:only="react"
        content={content}
        theme={theme}
        transition={transition}
        controls={controls}
        progress={progress}
      />
    </div>
  </body>
</html>

<style>
  body {
    margin: 0;
    padding: 0;
    background: #000;
    overflow: hidden;
  }

  .container {
    width: 100%;
    height: 100vh;
    position: relative;
  }

  .container :global(.reveal) {
    width: 100% !important;
    height: 100% !important;
  }
</style>
