---
import Reveal from "@/components/Reveal";

const base = ((import.meta.env.BASE_URL || "/") + "/").replace(/\/\/$/, "/");
---

<footer class="border-t border-border bg-background">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <Reveal client:visible>
    <div class="py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2 text-xs text-muted-foreground">
        <span>© {new Date().getFullYear()} CodingSkuy!. Learning Journal &amp; Engineering Repository.</span>
      </div>

      <div class="flex items-center gap-2 text-xs text-muted-foreground">
        <a
          href={`${base}doodles`}
          class="hover:text-primary transition-colors"
        >
          Doodles
        </a>
        <span aria-hidden="true" class="opacity-40">|</span>
        <a
          href={`${base}rss.xml`}
          target="_blank"
          class="hover:text-primary transition-colors"
        >
          <img
            src="/rss.svg"
            alt="RSS"
            width={16}
            height={16}
            class="w-4 h-4 opacity-60 hover:opacity-100 transition-opacity"
          />
        </a>
      </div>
    </div>
    </Reveal>
  </div>
</footer>
