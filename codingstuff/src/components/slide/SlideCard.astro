---
import { formatDate } from "@/lib/utils";
import { SlideViewer } from "./slide-viewer";

export interface Slide {
  id: string;
  title: string;
  author?: string;
  description?: string;
  tags?: string[];
  pubDate: Date;
  theme: string;
  transition: string;
}

interface Props {
  slide: Slide;
}

const { slide } = Astro.props;

const slideContent = `
## ${slide.title}${slide.author ? `\n\n*${slide.author}*` : ""}\n\n${formatDate(slide.pubDate)}`;
---

<div
  class="group hover:shadow-lg cursor-pointer w-full flex flex-col rounded-2xl border bg-card text-card-foreground shadow"
  style="transition: all 300ms cubic-bezier(0.34, 1.56, 0.64, 1);"
>
  <div
    class="w-full aspect-video p-0 relative rounded-2xl overflow-hidden slide-preview"
  >
    <SlideViewer
      content={slideContent}
      theme={slide.theme}
      transition={slide.transition}
      controls={false}
      progress={false}
      preview={true}
      client:only="react"
    />
  </div>
</div>
