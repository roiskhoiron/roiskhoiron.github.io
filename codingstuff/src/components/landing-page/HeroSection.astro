---
import { DOODLE_EMOJIS } from "@/consts";
import type { Doodle } from "@/schemas/content/doodle";
import ScrollingTags from "./ScrollingTags.astro";

export interface Props {
  uniqueTags: string[];
  doodle?: Doodle & { href: string };
}

const { uniqueTags, doodle } = Astro.props as Props;
const doodleEmoji =
  DOODLE_EMOJIS[Math.floor(Math.random() * DOODLE_EMOJIS.length)];
---

<section
  class="relative h-[calc(100vh-4rem)] overflow-hidden"
>
  <div
    class="absolute inset-0 bg-[linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] bg-size-[4rem_4rem] mask-[radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)] animate-pulse opacity-[0.03]"
  >
  </div>

  <div class="bg-primary/5 absolute top-[-10%] left-[-10%] -z-10 h-[500px] w-[500px] rounded-full blur-3xl animate-float" />
  <div class="bg-accent/10 absolute right-[-5%] bottom-[10%] -z-10 h-[400px] w-[400px] rounded-full blur-3xl animate-float" style="animation-delay: -3s; animation-duration: 8s;" />
  <div class="top-1/2 right-1/3 w-64 h-64 bg-purple-500/10 rounded-full blur-2xl absolute -z-10 animate-float" style="animation-delay: -1.5s; animation-duration: 7s;" />

  <ScrollingTags uniqueTags={uniqueTags} />

  <div
    class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 h-full flex items-center pointer-events-none"
  >
    <div class="text-center w-full">
      <div
        class="relative flex flex-col justify-center items-center pointer-events-auto"
        id="mona-text"
      >
        {
          doodle ? (
            <h1 class="mb-4 text-5xl font-bold tracking-tight text-foreground sm:text-7xl">
              <span class="relative inline-block text-primary text-glow animate-pulse">
                {doodleEmoji}
              </span>
              &nbsp;{doodle.title}
            </h1>
          ) : (
            <h1 class="mb-4 text-5xl font-bold tracking-tight text-foreground sm:text-7xl">
              <span class="bg-gradient-to-r from-[var(--brand-from)] via-[var(--brand-via)] to-[var(--brand-to)] bg-clip-text text-transparent">
                CodingSkuy!
              </span>
            </h1>
          )
        }

        <div id="hero-content" class="text-foreground/80">
          {
            doodle ? (
              <p>
                {doodle.description}
              </p>
            ) : (
              <p>
                Learning Journal &amp; Engineering Repository — documenting
                the process, sharing the architecture, building in public.
              </p>
            )
          }
        </div>

        {
          doodle && (
            <a
              href={doodle.href}
              class="mt-6 inline-flex items-center gap-2 px-6 py-3 bg-primary/10 hover:bg-primary/20 rounded-full transition-colors opacity-0 translate-y-2 pointer-events-none transform text-primary font-semibold"
              data-hero-button
            >
              Know More →
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>

<script>
  import { type Target } from "animejs";
  import { splitText } from "animejs/text";
  import { createTimeline } from "animejs/timeline";
  import { stagger } from "animejs/utils";

  document.addEventListener("DOMContentLoaded", () => {
    const heroContent = document.getElementById("hero-content");
    const heroButton = document.querySelector(
      "[data-hero-button]",
    ) as HTMLAnchorElement | null;

    const startTags = () => {
      document.dispatchEvent(new Event("start-tags"));
    };

    const revealButton = () => {
      if (!heroButton) {
        startTags();
        return;
      }

      const buttonTimeline = createTimeline({});

      buttonTimeline.add(heroButton, {});

      buttonTimeline.init().then(() => {
        heroButton.classList.remove(
          "opacity-0",
          "translate-y-2",
          "pointer-events-none",
        );
        heroButton.classList.add("pointer-events-auto");
        startTags();
      });
    };

    if (heroContent) {
      const { chars } = splitText(heroContent, {
        words: false,
        chars: true,
      });

      const headlineTimeline = createTimeline({
        loop: false,
        defaults: { ease: "inOut(3)", duration: 1500 },
      });

      headlineTimeline
        .add(
          chars,
          {
            y: [
              (target: Target) => {
                if (!(target instanceof HTMLElement)) {
                  return "0%";
                }

                const line = Number(target.dataset.line ?? 0);
                return line % 2 ? "100%" : "-200%";
              },
              "0%",
            ],
            opacity: [0, 1],
          },
          stagger(10, { from: "random" }),
        )
        .init()
        .then(revealButton);
    } else {
      revealButton();
    }
  });
</script>
