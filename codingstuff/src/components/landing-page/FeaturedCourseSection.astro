---
import Hoverable from "@/components/Hoverable";
import Reveal from "@/components/Reveal";
import { getChapterCount } from "@/lib/course";
import { getCategoryColor } from "@/lib/utils";
import type { StructureItemType } from "@/schemas/content/course";

interface CourseData {
  id: string;
  title: string;
  description: string;
  author?: string;
  pubDate: Date;
  cover?: string;
  structure: StructureItemType[];
}

interface Props {
  course: CourseData;
}

const { course } = Astro.props;
const courseSlug = course.id.replace(/\/toc$/, "");
const chapterCount = getChapterCount(course.structure);
---

<Reveal client:visible>
<section class="bg-card/50 py-8">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h2 class="mb-4 text-3xl font-bold text-foreground">
          Featured <span class="text-lumen">Course</span>
        </h2>
        <p class="text-muted-foreground">
          Structured learning that grows out of our explorations and builds.
        </p>
      </div>
      <a
        href="/courses"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-transparent px-4 py-2 text-sm font-medium text-muted-foreground shadow-xs transition-all duration-300 hover:scale-105 hover:bg-secondary hover:text-secondary-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 outline-none"
        style="min-width: 150px"
      >
        All Courses
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <Hoverable client:visible lift={4}>
    <a
      href={`/courses/${courseSlug}`}
      class="group block overflow-hidden rounded-2xl border-none bg-card shadow-lg transition-shadow duration-200 hover:shadow-xl"
    >
      <div class="flex flex-col md:flex-row">
        <div
          class="relative aspect-video w-full md:aspect-auto md:w-1/4 shrink-0"
        >
          {
            course.cover ? (
              <img
                src={course.cover}
                alt={course.title}
                class="h-full w-full object-cover"
              />
            ) : (
              <div
                class={`flex h-full min-h-40 w-full items-center justify-center bg-linear-to-br ${getCategoryColor(course.id)}`}
              >
                <svg
                  class="h-16 w-16 text-muted-foreground/30"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                  />
                </svg>
              </div>
            )
          }
        </div>

        <div class="flex flex-1 flex-col justify-between p-6">
          <div>
            <h3
              class="font-heading text-xl font-bold text-foreground group-hover:text-primary transition-colors"
            >
              {course.title}
            </h3>
            <p class="mt-2 line-clamp-2 text-sm text-muted-foreground">
              {course.description}
            </p>
          </div>

          <div class="mt-4 flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center gap-4 text-xs text-muted-foreground">
              <span class="flex items-center gap-1.5">
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
                  ></path>
                </svg>
                {chapterCount} chapters
              </span>
              {
                course.author && (
                  <span class="flex items-center gap-1.5">
                    <svg
                      class="h-4 w-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                      />
                    </svg>
                    {course.author}
                  </span>
                )
              }
            </div>
            <span
              class="inline-flex items-center gap-2 text-xs font-semibold text-primary group-hover:underline"
            >
              Start Learning
              <svg
                class="h-4 w-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </span>
          </div>
        </div>
      </div>
    </a>
    </Hoverable>
  </div>
</section>
</Reveal>
